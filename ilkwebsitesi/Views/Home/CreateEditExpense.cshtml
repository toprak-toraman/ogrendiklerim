@{
    ViewData["Title"] = "Create / Edit";
}
@model ilkwebsitesi.Models.Expense;

<div class="text-center">
    <h1 class="display-4">Create or edit an expense</h1>

</div>

<form   asp-controller="Home"  asp-action="CreateEditExpenseForm">
    
    
    <input hidden class="form-control" type="number" placeholder="0" asp-for ="Id"/>
    <label class="mt-4">Value ₺</label>
    <input class="form-control" type="number" placeholder="0" asp-for ="Value""/>
    <label class="mt-4">Name</label>
    <input class="form-control" type="text" placeholder="Add a name" asp-for="Name" />

    <button class="bnt btn-primary mt-4" type="submit">Ok</button>
</form>