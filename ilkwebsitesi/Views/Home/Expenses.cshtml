@{
    ViewData["title"] = "Expenses";
}
@model List<Expense>


<div class="text-center">
<h1 class="display-4">Expenses</h1>
<br />
<hr />
<h3>Total expenses $@ViewBag.Expenses</h3>
<br />

<table class="table">
    <thead>
    <tr>
            <th>Id</th>
            <th>Value</th>
            <th>Name</th>
            <th>Action</th>
    </tr>
        </thead>
        <tbody>
            @{
                
                foreach (var expense in Model){
    <tr> 
            <td>@expense.Id</td>
            <td>@expense.Value.ToString("N2")</td>
            <td> @expense.Name</td>
                        <td>
                            <a asp-action="CreateEditExpense" asp-route-id="@expense.Id">Edit</a>
                            <a asp-action="ItemDelete" asp-route-id="@expense.Id">Delete</a>
                        </td>
    </tr>
                }
            }
           
        </tbody>
        




</table>
</div>